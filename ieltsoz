    <!-- INTERAKTIV INTEGRATSIYA JAVASCRIPT -->
    <script>
        let selectedStatus = null;
        let activeCardRef = null;

        // Sahifalar navigatsiyasini boshqarish (SPA uslubi)
        function showSection(sectionId) {
            // Hamma sectionlarni yopish
            document.getElementById('section-home').classList.add('hidden');
            document.getElementById('section-tools').classList.add('hidden');
            document.getElementById('section-tests').classList.add('hidden');
            document.getElementById('section-leaderboard').classList.add('hidden');
            
            // Keraklisini ochish
            document.getElementById('section-' + sectionId).classList.remove('hidden');
            
            // Tepaga qaytarish silliq holatda
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        // Testni boshlash triggers
        function startSpecificTest(skill) {
            document.getElementById('test-skill-badge').innerText = skill + ' Academic';
            // Banner va tugmalarni tozalash
            const banner = document.getElementById('ai-feedback-banner');
            banner.classList.add('hidden');
            
            document.querySelectorAll('.option-card').forEach(c => {
                c.className = "option-card w-full text-left bg-white border-2 border-gray-200 p-4 rounded-2xl font-bold flex items-center space-x-4 shadow-[0_4px_0_#e2e8f0] btn-3d";
                c.querySelector('span:first-child').className = "w-8 h-8 rounded-lg bg-gray-100 text-gray-400 flex items-center justify-center border border-gray-200 text-sm";
            });

            selectedStatus = null;
            activeCardRef = null;

            showSection('tests');
        }

        // Variantni tanlash logikasi (Duolingo Style selection toggles)
        function selectPracticeOption(element, status) {
            // Agar javob tekshirib bo'lingan bo'lsa, variantni o'zgartirib bo'lmaydi
            if (document.getElementById('ai-feedback-banner').classList.contains('bg-green-100') || 
                document.getElementById('ai-feedback-banner').classList.contains('bg-red-100')) {
                return;
            }

            // Barcha kartalarni default holatga keltirish
            document.querySelectorAll('.option-card').forEach(card => {
                card.classList.remove('border-[#185adb]', 'bg-blue-50/50', 'shadow-[#185adb]');
                card.querySelector('span:first-child').className = "w-8 h-8 rounded-lg bg-gray-100 text-gray-400 flex items-center justify-center border border-gray-200 text-sm";
            });

            // Faqat bosilganga aktiv stil berish
            element.classList.add('border-[#185adb]', 'bg-blue-50/50', 'shadow-[#185adb]');
            element.querySelector('span:first-child').className = "w-8 h-8 rounded-lg bg-blue-100 text-[#185adb] flex items-center justify-center border border-[#185adb] text-sm font-bold";
            
            selectedStatus = status;
            activeCardRef = element;
        }

        // Javobni tekshirish (AI instant evaluation layer)
        function verifyAnswer() {
            if (!selectedStatus) {
                alert("Iltimos, avval variantlardan birini tanlang!");
                return;
            }

            const banner = document.getElementById('ai-feedback-banner');
            banner.classList.remove('hidden');

            if (selectedStatus === 'correct') {
                banner.className = "rounded-2xl p-4 font-bold flex items-center space-x-3 bg-green-100 text-green-800 border-2 border-green-200";
                banner.innerHTML = `<i class="fa-solid fa-circle-check text-xl"></i> <span>Ajoyib! To'g'ri javob topsangiz Band 8.0+ darajaga erishishingiz mumkin.</span>`;
                
                if (activeCardRef) {
                    activeCardRef.className = "option-card w-full text-left bg-green-50 border-2 border-green-500 p-4 rounded-2xl font-bold flex items-center space-x-4 shadow-[0_4px_0_#22c55e] btn-3d";
                    activeCardRef.querySelector('span:first-child').className = "w-8 h-8 rounded-lg bg-green-500 text-white flex items-center justify-center text-sm font-bold";
                }
            } else {
                banner.className = "rounded-2xl p-4 font-bold flex items-center space-x-3 bg-red-100 text-red-800 border-2 border-red-200";
                banner.innerHTML = `<i class="fa-solid fa-circle-xmark text-xl"></i> <span>Noto'g'ri. 'Crucial' matndagi eng mos sinonim hisoblanadi. Matnni qayta ko'ring.</span>`;
                
                if (activeCardRef) {
                    activeCardRef.className = "option-card w-full text-left bg-red-50 border-2 border-red-500 p-4 rounded-2xl font-bold flex items-center space-x-4 shadow-[0_4px_0_#ef4444] btn-3d";
                    activeCardRef.querySelector('span:first-child').className = "w-8 h-8 rounded-lg bg-red-500 text-white flex items-center justify-center text-sm font-bold";
                }
            }
        }
    </script>
</body>
</html>
